generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  HR_MANAGER
  MANAGER
  EMPLOYEE
}

enum Gender {
  MASCULINO
  FEMENINO
  OTRO
}

enum ContractType {
  INDEFINIDO
  PLAZO_FIJO
  EVENTUAL
  CONSULTORIA
  PASANTIA
}

enum LeaveStatus {
  PENDIENTE
  APROBADA
  RECHAZADA
  CANCELADA
}

enum AttendanceStatus {
  PRESENTE
  AUSENTE
  TARDANZA
  PERMISO
  VACACION
  FERIADO
}

enum RecruitmentStatus {
  ABIERTA
  EN_PROCESO
  CERRADA
  CANCELADA
}

enum ApplicantStatus {
  RECIBIDO
  EN_REVISION
  ENTREVISTA
  PRUEBA_TECNICA
  SELECCIONADO
  RECHAZADO
  CONTRATADO
}

enum ExpenseStatus {
  BORRADOR
  ENVIADO
  APROBADO
  RECHAZADO
  PAGADO
}

enum PayrollStatus {
  BORRADOR
  PROCESADO
  APROBADO
  PAGADO
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  role          Role      @default(EMPLOYEE)
  avatar        String?
  isActive      Boolean   @default(true)
  employeeId    String?   @unique
  employee      Employee? @relation(fields: [employeeId], references: [id])
  notifications Notification[]
  activityLogs  ActivityLog[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Employee {
  id               String    @id @default(cuid())
  employeeCode     String    @unique
  firstName        String
  lastName         String
  email            String    @unique
  phone            String?
  birthDate        DateTime?
  gender           Gender?
  nationalId       String?   @unique
  address          String?
  city             String?
  photoUrl         String?
  hireDate         DateTime  @default(now())
  terminationDate  DateTime?
  isActive         Boolean   @default(true)
  salary           Float     @default(0)
  contractType     ContractType @default(INDEFINIDO)

  departmentId     String?
  department       Department? @relation(fields: [departmentId], references: [id])
  positionId       String?
  position         Position?   @relation(fields: [positionId], references: [id])
  managerId        String?
  manager          Employee?   @relation("ManagerSubordinates", fields: [managerId], references: [id])
  subordinates     Employee[]  @relation("ManagerSubordinates")

  user             User?
  attendances      Attendance[]
  leaveRequests    LeaveRequest[]
  payrolls         Payroll[]
  performanceReviews PerformanceReview[] @relation("ReviewedEmployee")
  reviewsGiven     PerformanceReview[]  @relation("Reviewer")
  goals            PerformanceGoal[]
  trainings        TrainingEnrollment[]
  documents        Document[]
  contracts        Contract[]
  expenses         Expense[]
  assets           Asset[]
  emergencyContacts EmergencyContact[]
  skills           EmployeeSkill[]
  salaryHistory    SalaryHistory[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Department {
  id          String     @id @default(cuid())
  name        String     @unique
  code        String     @unique
  description String?
  headId      String?
  budget      Float?     @default(0)
  isActive    Boolean    @default(true)
  employees   Employee[]
  positions   Position[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Position {
  id           String     @id @default(cuid())
  title        String
  code         String     @unique
  description  String?
  salaryMin    Float?
  salaryMax    Float?
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  employees    Employee[]
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Attendance {
  id         String           @id @default(cuid())
  employeeId String
  employee   Employee         @relation(fields: [employeeId], references: [id])
  date       DateTime
  checkIn    DateTime?
  checkOut   DateTime?
  status     AttendanceStatus @default(PRESENTE)
  hoursWorked Float?
  overtime   Float?           @default(0)
  notes      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([employeeId, date])
}

model LeaveType {
  id            String         @id @default(cuid())
  name          String         @unique
  daysPerYear   Int            @default(15)
  isPaid        Boolean        @default(true)
  description   String?
  leaveRequests LeaveRequest[]
  createdAt     DateTime       @default(now())
}

model LeaveRequest {
  id          String      @id @default(cuid())
  employeeId  String
  employee    Employee    @relation(fields: [employeeId], references: [id])
  leaveTypeId String
  leaveType   LeaveType   @relation(fields: [leaveTypeId], references: [id])
  startDate   DateTime
  endDate     DateTime
  totalDays   Int
  reason      String?
  status      LeaveStatus @default(PENDIENTE)
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Payroll {
  id           String        @id @default(cuid())
  employeeId   String
  employee     Employee      @relation(fields: [employeeId], references: [id])
  period       String
  month        Int
  year         Int
  baseSalary   Float
  overtime     Float         @default(0)
  bonuses      Float         @default(0)
  deductions   Float         @default(0)
  tax          Float         @default(0)
  afp          Float         @default(0)
  healthIns    Float         @default(0)
  netSalary    Float
  status       PayrollStatus @default(BORRADOR)
  paidAt       DateTime?
  items        PayrollItem[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([employeeId, month, year])
}

model PayrollItem {
  id        String   @id @default(cuid())
  payrollId String
  payroll   Payroll  @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  concept   String
  type      String   // INGRESO, DESCUENTO
  amount    Float
  createdAt DateTime @default(now())
}

model JobPosting {
  id            String            @id @default(cuid())
  title         String
  description   String
  requirements  String?
  salaryMin     Float?
  salaryMax     Float?
  location      String?
  departmentId  String?
  status        RecruitmentStatus @default(ABIERTA)
  closingDate   DateTime?
  applicants    Applicant[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model Applicant {
  id           String          @id @default(cuid())
  fullName     String
  email        String
  phone        String?
  resumeUrl    String?
  coverLetter  String?
  status       ApplicantStatus @default(RECIBIDO)
  rating       Int?
  notes        String?
  jobPostingId String
  jobPosting   JobPosting      @relation(fields: [jobPostingId], references: [id])
  interviews   Interview[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model Interview {
  id          String    @id @default(cuid())
  applicantId String
  applicant   Applicant @relation(fields: [applicantId], references: [id])
  date        DateTime
  type        String    // TELEFONICA, PRESENCIAL, VIRTUAL
  interviewer String
  feedback    String?
  rating      Int?
  status      String    @default("PROGRAMADA") // PROGRAMADA, REALIZADA, CANCELADA
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model PerformanceReview {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation("ReviewedEmployee", fields: [employeeId], references: [id])
  reviewerId   String
  reviewer     Employee @relation("Reviewer", fields: [reviewerId], references: [id])
  period       String
  rating       Int      // 1-5
  strengths    String?
  improvements String?
  comments     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PerformanceGoal {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  title       String
  description String?
  targetDate  DateTime?
  progress    Int      @default(0) // 0-100
  status      String   @default("EN_PROGRESO") // EN_PROGRESO, COMPLETADO, CANCELADO
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Training {
  id          String               @id @default(cuid())
  title       String
  description String?
  instructor  String?
  startDate   DateTime
  endDate     DateTime?
  maxCapacity Int?
  location    String?
  isOnline    Boolean              @default(false)
  enrollments TrainingEnrollment[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model TrainingEnrollment {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  trainingId  String
  training    Training @relation(fields: [trainingId], references: [id])
  status      String   @default("INSCRITO") // INSCRITO, EN_CURSO, COMPLETADO, ABANDONADO
  score       Float?
  certificate String?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  @@unique([employeeId, trainingId])
}

model Document {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  title      String
  category   String   // CONTRATO, CERTIFICADO, IDENTIDAD, OTRO
  fileUrl    String?
  fileSize   Int?
  mimeType   String?
  expiresAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Contract {
  id          String       @id @default(cuid())
  employeeId  String
  employee    Employee     @relation(fields: [employeeId], references: [id])
  type        ContractType
  startDate   DateTime
  endDate     DateTime?
  salary      Float
  description String?
  fileUrl     String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Expense {
  id          String        @id @default(cuid())
  employeeId  String
  employee    Employee      @relation(fields: [employeeId], references: [id])
  category    String
  amount      Float
  currency    String        @default("BOB")
  description String?
  receiptUrl  String?
  date        DateTime
  status      ExpenseStatus @default(BORRADOR)
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Asset {
  id          String    @id @default(cuid())
  name        String
  code        String    @unique
  category    String
  description String?
  value       Float?
  assignedTo  String?
  employee    Employee? @relation(fields: [assignedTo], references: [id])
  assignedAt  DateTime?
  condition   String    @default("BUENO") // BUENO, REGULAR, MALO
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model EmergencyContact {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id])
  name         String
  relationship String
  phone        String
  email        String?
  createdAt    DateTime @default(now())
}

model Skill {
  id        String          @id @default(cuid())
  name      String          @unique
  category  String?
  employees EmployeeSkill[]
  createdAt DateTime        @default(now())
}

model EmployeeSkill {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  skillId    String
  skill      Skill    @relation(fields: [skillId], references: [id])
  level      Int      @default(1) // 1-5
  createdAt  DateTime @default(now())

  @@unique([employeeId, skillId])
}

model SalaryHistory {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  oldSalary  Float
  newSalary  Float
  reason     String?
  effectiveDate DateTime
  createdAt  DateTime @default(now())
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  priority  String   @default("NORMAL") // BAJA, NORMAL, ALTA, URGENTE
  authorId  String
  isActive  Boolean  @default(true)
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("INFO") // INFO, WARNING, SUCCESS, ERROR
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}

model CompanySettings {
  id           String  @id @default(cuid())
  companyName  String  @default("NovaTech Bolivia")
  logo         String?
  address      String?
  phone        String?
  email        String?
  website      String?
  taxId        String? // NIT
  currency     String  @default("BOB")
  timezone     String  @default("America/La_Paz")
  workHoursStart String @default("08:00")
  workHoursEnd  String @default("18:00")
  workDays     String  @default("1,2,3,4,5") // Mon-Fri
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  address   String?
  city      String?
  phone     String?
  isMain    Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
